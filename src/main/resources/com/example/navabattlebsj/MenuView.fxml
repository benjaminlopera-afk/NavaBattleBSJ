<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.navabattlebsj.controllers.MenuController"
            prefWidth="400" prefHeight="300">
    <VBox spacing="20" alignment="CENTER"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Label text="NavaBattle" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        <Button fx:id="newGameButton" text="Nueva Partida" prefWidth="180" onAction="#handleNewGame"/>
        <Button fx:id="loadGameButton" text="Cargar Partida" prefWidth="180" onAction="#handleLoadGame"/>
    </VBox>
</AnchorPane>