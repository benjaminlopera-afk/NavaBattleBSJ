<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.navabattlebsj.controllers.GameController"
      spacing="15" alignment="CENTER" prefWidth="900" prefHeight="650">

    <Label fx:id="statusLabel" text="Coloca tu flota para comenzar." styleClass="status-label"/>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="viewOpponentButton" text="Ver Tablero del Oponente"
                styleClass="button-secondary" disable="true" onAction="#handleViewOpponentBoard"/>
        <Button fx:id="startBattleButton" text="Comenzar Batalla"
                styleClass="button-primary" disable="true" onAction="#handleStartBattle"/>
    </HBox>

    <HBox spacing="30" alignment="CENTER">
        <VBox spacing="10" alignment="CENTER" styleClass="board-container">
            <Label text="Tablero de Posición" styleClass="section-label"/>
            <fx:include fx:id="positionBoard" source="BoardView.fxml"/>
        </VBox>

        <VBox spacing="10" alignment="CENTER" styleClass="board-container">
            <Label text="Tablero Principal" styleClass="section-label"/>
            <fx:include fx:id="mainBoard" source="BoardView.fxml"/>
        </VBox>
    </HBox>

</VBox>